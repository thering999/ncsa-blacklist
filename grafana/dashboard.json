{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "title": "NCSA Blacklist",
  "uid": "ncsa-blacklist",
  "version": 1,
  "schemaVersion": 36,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Total IPs",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "ncsa_store_size{type=\"ip\"}", "legendFormat": "IPs" }]
    },
    {
      "id": 2, "type": "stat", "title": "Total Domains",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "ncsa_store_size{type=\"domain\"}", "legendFormat": "Domains" }]
    },
    {
      "id": 3, "type": "stat", "title": "Total Hashes",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "ncsa_store_size{type=\"hash\"}", "legendFormat": "Hashes" }]
    },
    {
      "id": 4, "type": "stat", "title": "Feed Health",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background",
        "thresholds": { "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] } },
      "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "min(ncsa_feed_up)", "legendFormat": "All feeds up" }]
    },
    {
      "id": 5, "type": "stat", "title": "API Requests (1m)",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "rate(ncsa_requests_total[1m]) * 60", "legendFormat": "req/min" }]
    },
    {
      "id": 6, "type": "timeseries", "title": "Blacklist Size Over Time",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "list" } },
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "ncsa_store_size", "legendFormat": "{{type}}" }
      ]
    },
    {
      "id": 7, "type": "timeseries", "title": "Feed File Age (seconds)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "list" },
        "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 86400 }, { "color": "red", "value": 90000 }] } },
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "ncsa_feed_file_age_seconds", "legendFormat": "{{type}}" }
      ]
    },
    {
      "id": 8, "type": "timeseries", "title": "HTTP Requests by Status",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "rate(ncsa_requests_total[5m])", "legendFormat": "{{method}} {{path}} {{status}}" }
      ]
    },
    {
      "id": 9, "type": "timeseries", "title": "Blacklisted Lookups",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "rate(ncsa_lookup_hits_total[5m])", "legendFormat": "{{type}} hits/s" }
      ]
    },
    {
      "id": 10, "type": "table", "title": "Feed Status",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 6 },
      "options": { "sortBy": [{ "displayName": "Type" }] },
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "ncsa_feed_up", "legendFormat": "{{type}}", "instant": true },
        { "datasource": "${DS_PROMETHEUS}", "expr": "ncsa_feed_file_age_seconds / 3600", "legendFormat": "age_h {{type}}", "instant": true }
      ]
    }
  ]
}
