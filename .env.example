# Server
PORT=3939
DATA_DIR=./data

# Admin authentication (set at least one to protect /reload, /watch, /admin/*)
ADMIN_TOKEN=
ADMIN_TOKENS=alice:token1,bob:token2

# Restrict /admin/* to specific IP CIDRs (optional — leave blank to allow any IP)
# ADMIN_ALLOWED_IPS=10.0.0.0/8,192.168.0.0/16

# Prometheus metrics authentication (optional — leave blank to allow open access)
METRICS_TOKEN=

# CORS (optional — set to your frontend origin e.g. https://app.example.com)
CORS_ORIGIN=

# Per-IP rate limit (requests per minute, default: 60)
RATE_LIMIT=60

# Log format: leave blank for human-readable text, set to "json" for structured JSON logs
# LOG_FORMAT=json

# Email notifications (all required to enable)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=

# Line Notify (optional)
LINE_NOTIFY_TOKEN=

# Webhook (optional — receives POST JSON on sync events and stale alerts)
WEBHOOK_URL=
WEBHOOK_SECRET=

# Extra custom feeds (optional — comma-separated name:url pairs)
# EXTRA_FEEDS=mylist:https://example.com/feed.json
