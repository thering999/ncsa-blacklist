# ===================================
# NCSA Blacklist SOC Dashboard
# ไฟล์ตั้งค่า Environment Variables
#
# วิธีใช้:
#   Linux/macOS: cp .env.example .env && nano .env
#   Windows:     copy .env.example .env && notepad .env
# ===================================

# พอร์ตที่ dashboard รัน (default: 3939)
PORT=3939

# โฟลเดอร์เก็บข้อมูล feed (อย่าเปลี่ยนถ้าใช้ Docker)
DATA_DIR=/data

# ===== Admin Authentication =====
# ป้องกัน /admin/sync, /reload, /admin/* endpoints
# สร้าง token แบบสุ่ม: openssl rand -hex 32
# แนะนำให้ตั้งค่าเสมอก่อนใช้งานจริง
ADMIN_TOKEN=

# หลาย token (สำหรับหลายคน): ชื่อ:token,ชื่อ2:token2
ADMIN_TOKENS=

# จำกัด IP ที่เข้า /admin/* (แนะนำให้ตั้งค่าใน production)
# ตัวอย่าง: ADMIN_ALLOWED_IPS=10.0.0.0/8,192.168.0.0/16
ADMIN_ALLOWED_IPS=

# ===== Email Notifications =====
# ส่งอีเมลแจ้งเตือนเมื่อ sync เสร็จหรือพบ IP ใน watchlist
# ต้องตั้งค่าทุก field ถึงจะเปิดใช้งาน
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=

# ===== LINE Notify =====
# สำหรับแจ้งเตือนผ่าน LINE
# รับ token จาก: https://notify-bot.line.me/my/
LINE_NOTIFY_TOKEN=

# ===== Webhook =====
# รับ JSON POST เมื่อ sync เสร็จหรือพบ watchlist alert
WEBHOOK_URL=
WEBHOOK_SECRET=

# ===== Extra Feeds =====
# เพิ่ม feed นอกเหนือจาก NCSA (comma-separated name:url)
# ตัวอย่าง:
# EXTRA_FEEDS=mylist:https://feed.your-org.go.th/blacklist.json
EXTRA_FEEDS=

# ===== Security =====
# Prometheus metrics auth token
# ว่างเปล่า = เปิดให้ทุกคนเข้า /metrics
METRICS_TOKEN=

# CORS origin สำหรับ API (ว่างเปล่า = อนุญาตทุก origin)
# ตัวอย่าง: CORS_ORIGIN=https://soc.your-org.go.th
CORS_ORIGIN=

# Rate limit ต่อ IP (requests ต่อนาที, default: 60)
RATE_LIMIT=60

# Log format: ว่างเปล่า = human-readable, json = JSON structured logs
# LOG_FORMAT=json
